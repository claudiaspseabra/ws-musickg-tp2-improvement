@prefix music: <http://musickg.org/data/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sp: <http://spinrdf.org/sp#> .
@prefix spin: <http://spinrdf.org/spin#> .

music:Album spin:rule music:ClassifyReleaseEraRule .

music:Artist spin:rule music:ClassifyTrendingArtistRule .

music:Track spin:rule music:ClassifyHighEnergyTrackRule,
        music:ClassifyPopularTrackRule .

music:ClassifyHighEnergyTrackRule a sp:Construct,
        spin:Rule ;
    rdfs:label "Classify High Energy Tracks" ;
    sp:text """PREFIX music: <http://musickg.org/data/>
        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
        CONSTRUCT {
            ?this a music:HighEnergyTrack .
        }
        WHERE {
            ?this a music:Track ;
                  music:energy ?e .
            FILTER (xsd:float(?e) > 0.8)
        }""" .

music:ClassifyPopularTrackRule a sp:Construct,
        spin:Rule ;
    rdfs:label "Classify popular tracks" ;
    sp:text """PREFIX music: <http://musickg.org/data/>
        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
        CONSTRUCT {
            ?this a music:PopularTrack .
        }
        WHERE {
            ?this music:popularity ?popularity .
            FILTER (xsd:integer(?popularity) >= 70)
        }""" .

music:ClassifyReleaseEraRule a sp:Construct,
        spin:Rule ;
    rdfs:label "Classify release eras" ;
    sp:text """PREFIX music: <http://musickg.org/data/>
        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
        CONSTRUCT {
            ?this a music:ClassicAlbum . # O construtor base mapeia a assinatura da regra
        }
        WHERE {
            ?this a music:Album ;
                  music:releaseYear ?year .
            BIND(xsd:integer(?year) AS ?releaseYear)
            BIND(
                IF(?releaseYear >= 2000, music:ModernAlbum,
                  IF(?releaseYear < 2000, music:ClassicAlbum, music:TransitionAlbum)
                ) AS ?albumClass
            )
        }""" .

music:ClassifyTrendingArtistRule a sp:Construct,
        spin:Rule ;
    rdfs:label "Classify Trending Artists based on track popularity average" ;
    sp:text """PREFIX music: <http://musickg.org/data/>
        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
        CONSTRUCT {
            ?this a music:TrendingArtist .
        }
        WHERE {
            SELECT ?this WHERE {
                ?this a music:Artist .
                ?this music:performedBy ?this ;
                       music:popularity ?pop .
            }
            GROUP BY ?this
            HAVING (AVG(xsd:float(?pop)) >= 75.0)
        }""" .

